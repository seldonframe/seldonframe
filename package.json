{
  "name": "seldon-frame",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "dev": "turbo run dev --parallel",
    "dev:crm": "turbo run dev --filter=@seldonframe/crm",
    "dev:web": "turbo run dev --filter=@seldonframe/web",
    "build": "turbo run build",
    "build:crm": "turbo run build --filter=@seldonframe/crm",
    "build:web": "turbo run build --filter=@seldonframe/web",
    "start:crm": "pnpm --filter @seldonframe/crm start",
    "lint": "turbo run lint",
    "test:cross-block": "pnpm --filter @seldonframe/crm test:cross-block",
    "test:first-run": "node scripts/run-tsx.js packages/crm/tests/integration/first-run.spec.ts",
    "test:unit": "node scripts/run-unit-tests.js",
    "emit:blocks": "node scripts/emit-block-tools.js",
    "emit:blocks:check": "node scripts/emit-block-tools.js --check",
    "db:generate": "pnpm --filter @seldonframe/crm db:generate",
    "db:migrate": "pnpm --filter @seldonframe/crm db:migrate",
    "db:push": "pnpm --filter @seldonframe/crm db:push",
    "db:studio": "pnpm --filter @seldonframe/crm db:studio",
    "db:seed": "pnpm --filter @seldonframe/crm db:seed",
    "db:seed-demo": "pnpm --filter @seldonframe/crm db:seed-demo",
    "tsx": "node scripts/run-tsx.js"
  },
  "devDependencies": {
    "turbo": "^2.5.6"
  },
  "packageManager": "pnpm@10.18.1"
}
