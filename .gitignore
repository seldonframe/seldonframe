# See https://help.github.com/articles/ignoring-files/ for more about ignoring files.

# dependencies
/node_modules
/.pnp
.pnp.*
.yarn/*
!.yarn/patches
!.yarn/plugins
!.yarn/releases
!.yarn/versions

# testing
/coverage

# next.js
/.next/
**/.next/
/out/

# production
/build

# misc
.DS_Store
*.pem

# debug
npm-debug.log*
yarn-debug.log*
yarn-error.log*
.pnpm-debug.log*

# env files (can opt-in for committing if needed)
.env*

# vercel
.vercel

# typescript
*.tsbuildinfo
next-env.d.ts

# required root ignores
node_modules/
.next/
ui-ux-pro-max-skill/
.env
.env.local
.env.*.local
dist/
.turbo/
.vercel/

# MCPB desktop-extension bundles (built artifacts, not source)
*.mcpb

# Per-agent MCP registry entries (generated by
# scripts/gen-agent-server-jsons.mjs — build artifacts, not source; already
# covered by the blanket dist/ rule above, listed explicitly for clarity)
dist/agent-servers/

.vercel
.env*.local

# Docker self-host: ship the example, never the filled-in secrets
!.env.docker.example
