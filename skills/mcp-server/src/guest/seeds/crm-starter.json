{
  "name": "SeldonFrame CRM Starter",
  "description": "Default CRM objects + pipeline seeded into every new guest workspace. Mirrors packages/crm/src/db/seed-demo.ts.",
  "objects": [
    {
      "slug": "contacts",
      "label": "Contacts",
      "fields": [
        { "key": "full_name", "label": "Full name", "type": "text", "required": true },
        { "key": "email", "label": "Email", "type": "email", "required": true },
        { "key": "phone", "label": "Phone", "type": "phone" },
        { "key": "company", "label": "Company", "type": "text" },
        { "key": "source", "label": "Source", "type": "text" },
        { "key": "tags", "label": "Tags", "type": "multi-select" }
      ]
    },
    {
      "slug": "deals",
      "label": "Deals",
      "fields": [
        { "key": "title", "label": "Title", "type": "text", "required": true },
        { "key": "amount", "label": "Amount", "type": "currency" },
        { "key": "stage", "label": "Stage", "type": "pipeline-stage", "required": true },
        { "key": "close_date", "label": "Expected close", "type": "date" },
        { "key": "contact_id", "label": "Contact", "type": "relation", "relation": "contacts" }
      ]
    },
    {
      "slug": "activities",
      "label": "Activities",
      "fields": [
        { "key": "type", "label": "Type", "type": "select", "options": ["call", "email", "meeting", "note"] },
        { "key": "subject", "label": "Subject", "type": "text" },
        { "key": "at", "label": "When", "type": "datetime" },
        { "key": "contact_id", "label": "Contact", "type": "relation", "relation": "contacts" },
        { "key": "deal_id", "label": "Deal", "type": "relation", "relation": "deals" }
      ]
    }
  ],
  "pipelines": [
    {
      "slug": "sales",
      "label": "Sales pipeline",
      "stages": [
        { "key": "new", "label": "New lead", "probability": 10 },
        { "key": "qualified", "label": "Qualified", "probability": 25 },
        { "key": "proposal", "label": "Proposal sent", "probability": 50 },
        { "key": "negotiation", "label": "Negotiation", "probability": 75 },
        { "key": "won", "label": "Closed won", "probability": 100 },
        { "key": "lost", "label": "Closed lost", "probability": 0 }
      ]
    }
  ],
  "views": [
    { "slug": "contacts-all", "object": "contacts", "label": "All contacts", "layout": "table" },
    { "slug": "deals-board", "object": "deals", "label": "Pipeline", "layout": "kanban", "group_by": "stage" },
    { "slug": "activities-timeline", "object": "activities", "label": "Activity timeline", "layout": "timeline", "sort": "at:desc" }
  ]
}
