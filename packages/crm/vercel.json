{
  "framework": "nextjs",
  "installCommand": "pnpm install --frozen-lockfile",
  "buildCommand": "pnpm build",
  "crons": [
    {
      "path": "/api/cron/automations",
      "schedule": "0 */6 * * *"
    },
    {
      "path": "/api/cron/brain-compile",
      "schedule": "0 3 * * *"
    },
    {
      "path": "/api/cron/orphan-workspace-ttl",
      "schedule": "0 4 * * *"
    },
    {
      "path": "/api/cron/workflow-tick",
      "schedule": "* * * * *"
    },
    {
      "path": "/api/cron/report-contact-usage",
      "schedule": "0 2 * * *"
    }
  ]
}
