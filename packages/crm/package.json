{
  "name": "@seldonframe/crm",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "dev": "next dev",
    "build": "bash scripts/check-use-server.sh src && next build",
    "start": "next start",
    "lint": "eslint",
    "typecheck": "tsc --noEmit -p tsconfig.json",
    "check:use-server": "bash scripts/check-use-server.sh src",
    "db:generate": "drizzle-kit generate",
    "db:check-journaled": "node scripts/check-migrations-journaled.mjs",
    "db:assert-drift": "node scripts/assert-schema-drift.mjs",
    "db:migrate": "node scripts/check-migrations-journaled.mjs && node scripts/migrate-tolerant.mjs && node scripts/assert-schema-drift.mjs",
    "db:migrate:strict": "node -e \"if(!process.env.DATABASE_URL){console.log('[db:migrate] DATABASE_URL not set — skipping');process.exit(0)}\" && drizzle-kit migrate",
    "db:push": "drizzle-kit push",
    "db:studio": "drizzle-kit studio",
    "db:seed": "tsx src/db/seed.ts",
    "db:seed-demo": "tsx src/db/seed-demo.ts",
    "db:seed-hvac": "tsx src/db/seed-hvac-arizona.ts",
    "test:cross-block": "tsx src/testing/cross-block-smoke.ts",
    "template:validate": "tsx scripts/template-validate.ts",
    "blocks:emit": "tsx scripts/emit-blocks.ts",
    "blocks:emit:check": "tsx scripts/emit-blocks.ts --check"
  },
  "dependencies": {
    "@anthropic-ai/sdk": "^0.112.3",
