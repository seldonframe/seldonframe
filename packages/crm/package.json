    "markdown-to-jsx": "^9.8.2",
    "motion": "^12.42.2",
    "next": "16.2.10",
    "next-auth": "5.0.0-beta.30",
    "next-themes": "^0.4.6",
    "papaparse": "^5.5.4",
    "posthog-js": "^1.404.1",
    "posthog-node": "^5.45.2",
    "qrcode": "^1.5.4",
    "react": "19.2.7",
    "react-day-picker": "^9.14.0",
