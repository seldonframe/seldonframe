# 2026-05-19 — Proposal Builder env vars.
#
# Most of what Proposal Builder needs is already set in your environment
# (STRIPE_SECRET_KEY, NEXT_PUBLIC_APP_URL, WORKSPACE_BASE_DOMAIN,
# ANTHROPIC_API_KEY, CRON_SECRET). The only thing to verify before
# shipping is the Connect webhook signing secret.

# Webhook signing secret for Stripe Connect events. Distinct from the
# platform webhook secret. The same /api/webhooks/stripe/connect endpoint
# handles both SMB connected-account billing AND proposal subscriptions —
# make sure your Stripe Dashboard Connect endpoint listens to:
#   - checkout.session.completed   (proposal acceptance — Proposal Builder)
#   - payment_intent.succeeded     (existing SMB booking flow)
#   - payment_intent.payment_failed
#   - charge.refunded
#   - invoice.payment_succeeded
#   - invoice.payment_failed
#   - customer.subscription.created
#   - customer.subscription.updated
#   - customer.subscription.deleted
STRIPE_CONNECT_WEBHOOK_SECRET=

# #139 marketplace agent billing (P4). The endpoint secret for the marketplace
# settlement webhook (/api/v1/marketplace/stripe/webhook), which flips
# marketplace_purchases status on: checkout.session.completed, invoice.paid,
# invoice.payment_succeeded, invoice.payment_failed, customer.subscription.deleted.
# Unset → the webhook is inert (returns 400 "webhook_not_configured", never acts).
STRIPE_MARKETPLACE_WEBHOOK_SECRET=
# Marketplace fiat billing feature flag — the SINGLE billing flag. Default OFF
# (free-to-install). Set to "true" to enable agent Checkout/subscriptions + the
# buyer billing-portal link. Whether a charge is REAL ('live') vs 'test' is
# KEY-DERIVED: it's 'live' iff STRIPE_SECRET_KEY is a live key (sk_live_/rk_live_),
# else 'test' — so the mode label always matches the configured key (no separate
# go-live flag to fall out of sync). One-time AND subscription charges are PLATFORM
# destination charges, so the marketplace webhook is a normal PLATFORM endpoint.
SF_MARKETPLACE_BILLING=

# NOTE: STRIPE_CONNECT_CLIENT_ID was previously documented here but the
# code does NOT read it. Express accounts are created via direct API
# (stripe.accounts.create({ type: "express" })) using STRIPE_SECRET_KEY
# only. Client IDs are required for OAuth flows (Standard accounts),
# which Proposal Builder does not use.

# ─────────────────────────────────────────────────────────────────────────────
# 2026-06-01 — Voice agent PHASE 0 (Twilio SIP → OpenAI Realtime hello-world).
#
# Proves the transport: a real phone call connects to gpt-realtime-2, hears a
# hard-coded greeting, has one short exchange, hangs up. NO tools, NO DB, NO
# per-workspace logic. Webhook lives at:
#   POST /api/v1/voice/openai/webhook
# Runbook: docs/voice/phase-0-runbook.md
# ─────────────────────────────────────────────────────────────────────────────

# OpenAI API key with Realtime SIP beta access. Used to (a) accept the inbound
# SIP call (POST /v1/realtime/calls/{id}/accept) and (b) authenticate the
# realtime control WebSocket. Same key the rest of the platform uses for OpenAI.
OPENAI_API_KEY=

# Standard-Webhooks signing secret for the OpenAI webhook endpoint. Copy it from
# the OpenAI dashboard AFTER you register the webhook URL there (Settings →
# Webhooks). Format: whsec_<base64>. The /api/v1/voice/openai/webhook route
# verifies every `realtime.call.incoming` delivery against this and 401s any
# request whose signature doesn't match. REQUIRED — without it the route 400s
# ("missing_secret") and rejects all calls.
OPENAI_WEBHOOK_SECRET=

# The OpenAI Realtime project SIP address that your Twilio Elastic SIP Trunk's
# Origination URI points at. NOT read by application code (the inbound flow is
# driven entirely by the webhook + call_id) — documented here so the value
# lives next to the other voice vars and the runbook can reference it. Format:
#   sip:<your-openai-project-id>@sip.api.openai.com;transport=tls
OPENAI_REALTIME_PROJECT_SIP=

# (Twilio) No NEW Twilio secret is required for Phase 0: the call path is
# Twilio Trunk → OpenAI SIP → this webhook, so Twilio never calls our app for
# the voice leg. Your existing Twilio account/trunk credentials stay in the
# Twilio dashboard. The trunk's Origination URI is configured to the
# OPENAI_REALTIME_PROJECT_SIP value above (see the runbook). If you later want
# call-status callbacks hitting our app, the existing TWILIO_* integration vars
# already cover that.

# ─────────────────────────────────────────────────────────────────────────────
# 2026-06-01 — Voice agent PHASE 1 (booking tools + one real booking).
#
# Phase 1 wires the 6 booking tools (look_up_availability, book_appointment,
# find_my_existing_appointment, reschedule_appointment, cancel_appointment,
# escalate_to_human — provide_faq_answer is intentionally NOT exposed) into the
# validated voice transport, and books a REAL appointment into ONE configured
# test workspace. Per-workspace resolution from the dialed number is Phase 2.
# ─────────────────────────────────────────────────────────────────────────────

# The slug of the workspace that Phase 1 voice calls book into. On call start
# the webhook looks up this org by slug, resolves a website-chatbot agent id for
# it (or any agent row, or the org id as a placeholder), and runs the call with
# testMode:false — so a booking made by phone lands in this workspace's
# /bookings for real. Use a real workspace the operator already built, e.g.
#   VOICE_PHASE1_TEST_ORG_SLUG=spark-heating-cooling
# If unset (or the slug doesn't match a workspace), the call still answers but
# WITHOUT tools — the agent greets and chats but can't check availability or
# book. Logged as voice_call_workspace_unresolved.
VOICE_PHASE1_TEST_ORG_SLUG=

# ── Improve verb (eval replay → propose-only blueprint patches) ──────────────
# How many recent REAL conversations the improve run samples (validator-failed
# + negative-quality conversations are always taken first).
SF_IMPROVE_SAMPLE_SIZE=50
# Cap on eval scenarios per improve run (deterministic ones take priority).
SF_IMPROVE_MAX_SCENARIOS=24
# Max serialized size of a proposed blueprint patch, in bytes.
SF_IMPROVE_PATCH_MAX_BYTES=8192

# ── Referral credits (growth loop — INERT unless enabled) ────────────────────
# "true" enables referral recording + wallet credits. Absent/false = every
# referral entry point is a no-op. Credits are wallet-ledger rows only.
SF_REFERRALS_ENABLED=
# Credit amount per party (referrer AND referee), in cents. Default 500.
SF_REFERRAL_CREDIT_CENTS=500
