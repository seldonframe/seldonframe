    "name": "Client Brief",
    "fields": [{ "key": "company", "label": "Company", "type": "text", "required": true }]
  },
  "branding": { "primaryColor": "190 95% 39%", "accentColor": "262 83% 70%", "mood": "creative" },
  "rawInput": { "processDescription": "Discovery to retainer", "painPoint": "handoff clarity", "clientDescription": "SMB brands" },
