      "heroHeadline": "Creative & Growth Agency",
      "heroSubheadline": "Full-service brand, content, and performance marketing."
    },
    "email": {
      "enabled": true,
      "preferredProvider": "resend",
      "defaultFromName": "AgencyFlow",
