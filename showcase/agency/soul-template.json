      "bufferMinutes": 10,
      "allowWeekends": false
    },
    "landing": {
      "enabled": true,
      "defaultSections": [
        { "type": "hero", "title": "Grow Your Brand with Signal Studio" },
        { "type": "services", "title": "What We Do" },
        { "type": "case-studies", "title": "Our Work" },
        { "type": "cta", "title": "Let's Talk" }
