    "portal": {
      "enabled": true,
      "welcomeMessage": "Welcome to your client portal. Access project updates, deliverables, and invoices here.",
      "enableMessaging": true,
      "enableResources": true,
      "enableInvoices": true,
      "resourceCategories": ["Deliverables", "Brand Assets", "Reports", "Invoices"]
