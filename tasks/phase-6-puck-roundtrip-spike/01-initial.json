        "authorName": "Jane D.",
        "authorRole": "Patient since 2023",
        "rating": 5
      }
    },
    {
      "type": "FAQ",
      "props": {
        "id": "FAQ-main",
        "items": [
          {
            "question": "Do you accept walk-ins?",
