          },
          {
            "question": "Do you take our insurance?",
            "answer": "Most major plans — call to confirm."
          },
          {
            "question": "Cleaning cost?",
            "answer": "$120 for new patients."
          }
        ]
      }
    },
    {
      "type": "FormContainer",
      "props": {
        "id": "FormContainer-lead",
        "formName": "New patient",
