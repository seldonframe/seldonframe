      },
      {
        "type": "EmailInput",
        "props": {
          "id": "EmailInput-email",
          "label": "Email",
          "fieldName": "email"
        }
      },
      {
        "type": "TextInput",
        "props": {
          "id": "TextInput-phone",
          "label": "Phone",
          "placeholder": "(514) 555-0100",
          "fieldName": "phone",
          "required": "yes"
        }
